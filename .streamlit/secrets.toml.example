# Salin fail ni jadi .streamlit/secrets.toml (fail sebenar di-gitignore, jangan commit).
# Untuk Streamlit Community Cloud: tampal kandungan ni dalam "Secrets" projek.
#
# DATABASE_URL = connection string Supabase (guna SESSION POOLER / TRANSACTION POOLER URL,
# dari Supabase: Project Settings -> Database -> Connection string -> URI, pilih pooler).
# Pastikan prefix "postgresql+psycopg2://" dan letak password sebenar.

DATABASE_URL = "postgresql+psycopg2://postgres.xxxxxxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"
